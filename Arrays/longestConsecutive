class Main {
    public static void main(String[] args) {
        int[] arr = {100, 4, 200, 1, 3, 2};
        int longest = longestSequence(arr);
        System.out.println("Longest Consecutive Sequence Length: " + longest);
       
    }
    
    static int longestSequence(int arr[]){
        int maxLength = 0;
        for(int i=0;i<arr.length;i++){
            int current = arr[i];
            int count = 1;
            
            while(linearSearch(arr,current+1)){
                current+= 1;
                count++;
            }
            maxLength = Math.max(maxLength,count);
        }
        return maxLength;
    }
    
    static boolean linearSearch(int arr[],int k){
        for(int nums : arr){
            if(nums==k) return true;
        }
        return false;
    }
}