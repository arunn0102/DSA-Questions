class Main {
    public static void main(String[] args) {
       int arr[] = {5,3,2,4,1};
       int result = countInversion(arr);
       System.out.println(result);
    }
    
    static int countInversion(int arr[]){
        int count = 0;
        int n = arr.length;
        for(int i=0;i<n-1;i++){
            for(int j=i+1;j<n;j++){
                if(arr[i]>arr[j]){
                    count++;
                }
            }
        }
        return count;
    }
}