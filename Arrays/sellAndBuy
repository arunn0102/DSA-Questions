import java.util.*;
class Main {
    public static void main(String[] args) {
       int arr[] = {2,3,4,1,5,6};
       int result = stock(arr);
       System.out.println(result);
    }
    
    static int stock(int[] arr){
       int min = arr[0];
       int profit = 0;
       for(int i=1;i<arr.length;i++){
          int cost = arr[i]-min;
          profit = Math.max(min,cost);
           min = Math.min(min,arr[i]);
       }
       return profit;
    }
}