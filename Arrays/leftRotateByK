function rev(arr, start, end){
    while(start<end){
        let temp=arr[start]
        arr[start]=arr[end]
        arr[end]=temp
        start++
        end--
    }
    return arr
}


// Chatgpt Approach.............
import java.util.*;

class Main {
    public static void main(String[] args) {
        int[] arr = {1, 2, 3, 4, 5};
        int k = 2;
        int[] result = leftRotate(arr, k);
        System.out.println(Arrays.toString(result));  // Output: [3, 4, 5, 1, 2]
    }

    static int[] leftRotate(int[] arr, int k) {
        int n = arr.length;
        int[] rotated = new int[n];

        for (int i = 0; i < n; i++) {
            rotated[(i - k + n) % n] = arr[i];
        }

        return rotated;
    }
}





// Right Rotate by k............
import java.util.*;
class Main {
    public static void main(String[] args) {
       int[] arr = {1,2,3,4,5};
       int k = 3;
       int[] result = rotated(arr,k);
       System.out.println(Arrays.toString(result));
    }
    
    static int[] rotated(int arr[],int k){
        int n = arr.length;
        int[] rotated = new int[n];
        for(int i=0;i<arr.length;i++){
            rotated[(i + k) % n] = arr[i];
        }
        return rotated;
    }
}