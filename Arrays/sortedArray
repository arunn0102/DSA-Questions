import java.util.*;
public class sortedArray {
    public static void main(String[] args) {
        int arr[] = {2,4,6,8};
        System.out.println(sort(arr));
    }
    static boolean sort(int arr[]){
        for(int i=1;i<arr.length;i++){
            if (arr[i]<arr[i-1]) 
                return false;
        }
     return true;
    }
    
}
