class Main {
    public static void main(String[] args) {
        int arr[] = {-1,2,3,3,4,6,-1};
        int k=4;
        System.out.println(max(arr,k));
    }
    
    static int max(int arr[], int k){
        int maxSum = -1;
        int sum=0;
        for(int i=0;i<k;i++){
            sum+=arr[i];
        }
        maxSum=sum;
        for(int i=k;i<arr.length;i++){
            sum=sum-arr[i-k]+arr[i];
            maxSum=Math.max(sum,maxSum);
        }
        return maxSum;
    }
}