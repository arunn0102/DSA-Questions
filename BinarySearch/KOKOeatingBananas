let arr=[3,6,7,11]
let h=8
console.log(koko(arr,h));

function max(arr){
    let maxi=arr[0]
    for(let i=1;i<arr.length;i++){
        if(arr[i]>maxi){
            maxi=arr[i]
        }
    }
    return maxi
}

function koko(arr,h){
    let low=1, high=max(arr), ans=Number.MAX_VALUE;
    while(low<=high){
        let mid=Math.floor((low+high)/2)
        let reqtime= count(arr,mid)
        if(reqtime<=h){
            ans=mid
            high=mid-1
        } else {
            low=mid+1
        }
    }
    return ans
}

function count(arr,hours){
    let totalhr=0
    for(let i=0;i<arr.length;i++){
        totalhr+=Math.ceil(arr[i]/hours)
    }
    return totalhr
}