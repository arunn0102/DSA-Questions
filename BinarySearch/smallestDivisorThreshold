function threshold(arr,th){
    let low=0, high=max(arr), ans=Number.MAX_VALUE
    while(low<=high){
        let mid=Math.floor((low+high)/2)
        if(sumbyth(arr,mid)<=th){
            ans=mid
            high=mid-1
        } else{
            low=mid+1
        }
    }
    return ans
}

function sumbyth(arr,h){
    let sum=0
    for(let i=0;i<arr.length;i++){
        sum+=Math.ceil(arr[i]/h)
    }
    return sum
}

function max(arr){
    let maxi=arr[0];
    for(let i=0;i<arr.length;i++){
        if(arr[i]>maxi){
            maxi=arr[i]
        }
    }
    return maxi
}