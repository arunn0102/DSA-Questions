class Main {
    public static void main(String[] args) {
        String s1 = "listen";
        String s2 = "silent";
        boolean result = anagrams(s1,s2);
        System.out.println(result);
    }
    
    static boolean anagrams(String s1, String s2){
        char a[] = s1.toCharArray();
        char b[] = s2.toCharArray();
        
        Arrays.sort(a);
        Arrays.sort(b);
        
        return Arrays.equals(a,b);
    }
}